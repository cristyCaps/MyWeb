---
import Layout from "./layouts/layout.astro";
---

<Layout title="Welcome">
  <main class="min-h-screen bg-gradient-to-br from-sky-100 via-sky-200 to-sky-300 flex flex-col items-center justify-center relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-10 left-10 w-32 h-32 bg-sky-300 rounded-full opacity-20 blur-xl"></div>
    <div class="absolute bottom-10 right-10 w-48 h-48 bg-sky-400 rounded-full opacity-20 blur-xl"></div>
    <div class="absolute top-1/3 right-20 w-24 h-24 bg-sky-200 rounded-full opacity-30 blur-lg"></div>
    
    <!-- Welcome Modal -->
    <div id="welcomeModal" class="bg-white/90 backdrop-blur-lg rounded-3xl shadow-2xl p-20 max-w-5xl mx-4 text-center relative z-10 border border-blue-200">
      <!-- Decorative top accent -->
      <div class="absolute top-0 left-1/2 transform -translate-x-1/2 w-24 h-1 bg-gradient-to-r from-blue-400 to-blue-600 rounded-full"></div>
      
      <h1 class="text-7xl font-extrabold bg-gradient-to-r from-blue-500 to-blue-700 bg-clip-text text-transparent mb-10 tracking-tight">
        Welcome!
      </h1>
      
      <p class="text-4xl text-gray-700 mb-12 font-light leading-relaxed">
        May I help you?
      </p>
      
      <!-- Subtle decorative line -->
      <div class="w-24 h-0.5 bg-gradient-to-r from-transparent via-blue-300 to-transparent mx-auto"></div>
    </div>
    
    <!-- Interview Modal (hidden by default) -->
    <div id="interviewModal" class="hidden bg-white/90 backdrop-blur-lg rounded-3xl shadow-2xl p-20 max-w-5xl mx-4 text-center relative z-10 border border-blue-200">
      <!-- Decorative top accent -->
      <div class="absolute top-0 left-1/2 transform -translate-x-1/2 w-24 h-1 bg-gradient-to-r from-blue-400 to-blue-600 rounded-full"></div>
      
      <h1 class="text-6xl font-extrabold bg-gradient-to-r from-blue-500 to-blue-700 bg-clip-text text-transparent mb-8 tracking-tight">
        Interview Required
      </h1>
      
      <p class="text-3xl text-gray-700 mb-16 font-light leading-relaxed max-w-3xl mx-auto">
        Sure, but you need to pass the interview first in order to see what's inside
      </p>
      
      <!-- Buttons -->
      <div class="flex gap-6 justify-center">
        <button 
          id="okayButton"
          class="bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-semibold text-xl py-4 px-10 rounded-xl shadow-lg transition-all duration-300 transform hover:scale-105"
        >
          Okay
        </button>
        <button 
          id="backButton"
          class="bg-white border-2 border-blue-400 text-blue-600 hover:bg-blue-50 font-semibold text-xl py-4 px-10 rounded-xl shadow-lg transition-all duration-300 transform hover:scale-105"
        >
          Back
        </button>
      </div>
    </div>
    
    <!-- Question below with enhanced styling -->
    <div id="questionContainer" class="mt-12 text-center relative z-20">
      <button 
        id="comeInButton"
        class="text-3xl text-blue-800 font-medium tracking-wide hover:text-blue-900 transition-colors duration-300 cursor-pointer bg-transparent border-none p-0 hover:bg-transparent"
      >
        Can I come in?
      </button>
    </div>
  </main>
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
  
  main {
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const comeInButton = document.getElementById('comeInButton');
    const backButton = document.getElementById('backButton');
    const okayButton = document.getElementById('okayButton');
    
    function showInterviewModal() {
      const welcomeModal = document.getElementById('welcomeModal');
      const interviewModal = document.getElementById('interviewModal');
      const questionContainer = document.getElementById('questionContainer');
      
      if (welcomeModal && interviewModal && questionContainer) {
        welcomeModal.classList.add('hidden');
        interviewModal.classList.remove('hidden');
        questionContainer.classList.add('hidden');
      }
    }
    
    function handleBack() {
      const welcomeModal = document.getElementById('welcomeModal');
      const interviewModal = document.getElementById('interviewModal');
      const questionContainer = document.getElementById('questionContainer');
      
      if (welcomeModal && interviewModal && questionContainer) {
        interviewModal.classList.add('hidden');
        welcomeModal.classList.remove('hidden');
        questionContainer.classList.remove('hidden');
      }
    }
    
    function handleOkay() {
      window.location.href = '/interview';
    }
    
    // Add event listeners
    if (comeInButton) {
      comeInButton.addEventListener('click', showInterviewModal);
    }
    
    if (backButton) {
      backButton.addEventListener('click', handleBack);
    }
    
    if (okayButton) {
      okayButton.addEventListener('click', handleOkay);
    }
  });
</script>
