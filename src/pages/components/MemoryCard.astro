---
import type { Memory } from "../data/memories";

interface Props {
  memory: Memory;
  index: number;
}

const { memory, index } = Astro.props;
const isEven = index % 2 === 0;
---

<div
  class={`flex items-center justify-between w-full mb-12 ${isEven ? "flex-row" : "flex-row-reverse"}`}
>
  <div
    class="w-5/12 p-6 bg-white/10 backdrop-blur-md rounded-xl border border-white/20 shadow-xl"
  >
    <span class="text-sm font-mono text-pink-300">{memory.date}</span>
    <h2 class="text-2xl font-bold text-white mb-2">{memory.title}</h2>
    <p class="text-gray-200 text-sm leading-relaxed">{memory.description}</p>
  </div>

  <div class="w-2/12 flex justify-center relative">
    <div
      class={`w-4 h-4 rounded-full bg-gradient-to-br ${memory.color} shadow-[0_0_15px_rgba(236,72,153,0.6)] z-10`}
    >
    </div>
    <div class="absolute h-full w-0.5 bg-white/10 top-0"></div>
  </div>

  <div class="w-5/12">
    <img
      src={memory.image}
      alt={memory.title}
      class="rounded-xl shadow-2xl hover:scale-105 transition-transform duration-500 border-2 border-white/10"
      transition:name={`img-${memory.id}`}
    />
  </div>
</div>
